# Listen address for net/http Server.
HTTP_ADDR=:8080

# Redis connection (single instance).
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# Stable ID per running process; omit to auto-generate (recommended for multi-node later).
# GRIDLOCK_INSTANCE_ID=node-a

# Admin-only grid reset (POST /api/reset with header X-Admin-Key).
# Leave empty in dev if you do not need reset; production should set a long random value.
GRIDLOCK_ADMIN_KEY=change-me-in-production

# WebSocket session token lifetime (maps token -> user after POST /api/join).
WS_TOKEN_TTL_HOURS=24
